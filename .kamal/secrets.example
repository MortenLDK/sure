# .kamal/secrets.example — Template for Kamal secret injection
#
# Copy this file to .kamal/secrets and fill in real values:
#   cp .kamal/secrets.example .kamal/secrets
#
# .kamal/secrets is gitignored — NEVER commit real secrets to git.
#
# Commands to generate secrets:
#   SECRET_KEY_BASE:     openssl rand -hex 64
#   POSTGRES_PASSWORD:   openssl rand -base64 32
#   KAMAL_REGISTRY_PASSWORD: Create a GitHub PAT at https://github.com/settings/tokens
#                        Required scopes: write:packages (to push to GHCR)

KAMAL_REGISTRY_PASSWORD=ghp_CHANGE_ME
SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_hex_64
POSTGRES_USER=sure_user
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
POSTGRES_DB=sure_production
