# Kirkvik Family Finance — Environment Variables
# Copy to .env and fill in real values before deploying:
#   cp .env.kirkvik.example .env
#
# .env is gitignored — NEVER commit real secrets to git.
#
# Commands to generate secrets:
#   SECRET_KEY_BASE:     openssl rand -hex 64
#   POSTGRES_PASSWORD:   openssl rand -base64 32

SECRET_KEY_BASE=CHANGE_ME_generate_with_openssl_rand_hex_64
POSTGRES_USER=sure_user
POSTGRES_PASSWORD=CHANGE_ME_generate_with_openssl_rand_base64_32
POSTGRES_DB=sure_production
APP_DOMAIN=frihetsformuen.no

# Optional: OpenAI for AI chat features (Phase 9)
# OPENAI_ACCESS_TOKEN=

# Optional: Sidekiq Web UI credentials (set in production for /sidekiq dashboard)
# SIDEKIQ_WEB_USERNAME=admin
# SIDEKIQ_WEB_PASSWORD=CHANGE_ME
